# ---- Backend (services/api) ----
DATABASE_URL=postgresql+psycopg2://coach:coach_dev_password@localhost:5432/interview_coach
REDIS_URL=redis://localhost:6379/0

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Leave empty + MOCK_AI=true to run the full loop offline with mock agents.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MOCK_AI=true

# docker (safe, default) | subprocess (dev-only, NO isolation)
SANDBOX_MODE=docker
SANDBOX_IMAGE=ai-coach-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=10

CORS_ORIGINS=http://localhost:3000

# ---- Frontend (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
