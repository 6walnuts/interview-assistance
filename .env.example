# ---- Backend (services/api) ----
# 本地开发默认 SQLite（零依赖）。要用 Postgres 时换成下面注释里的地址。
DATABASE_URL=sqlite:///./dev.db
# DATABASE_URL=postgresql+psycopg2://coach:coach_dev_password@localhost:5432/interview_coach
REDIS_URL=redis://localhost:6379/0

# Single-user local mode: true = no registration/login needed, everything is
# saved under one local account (personal/offline use only — never in production).
LOCAL_MODE=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ---- AI provider ----
# Leave the key empty + MOCK_AI=true to run the full loop offline with mock agents.
# LLM_PROVIDER: openai | deepseek | kimi | anthropic
LLM_PROVIDER=openai
LLM_API_KEY=
# Optional overrides (empty = provider default):
#   openai    -> gpt-4o-mini
#   deepseek  -> deepseek-chat        (base_url https://api.deepseek.com)
#   kimi      -> kimi-latest          (base_url https://api.moonshot.cn/v1;
#                overseas accounts: LLM_BASE_URL=https://api.moonshot.ai/v1)
#   anthropic -> claude-opus-4-8      (cheaper: LLM_MODEL=claude-haiku-4-5)
LLM_MODEL=
LLM_BASE_URL=
MOCK_AI=true

# Legacy aliases, still honored when LLM_PROVIDER=openai:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Voice (语音输入/朗读，走 OpenAI 语音 API，仅 LLM_PROVIDER=openai 可用) ----
# 费用极低：转写约 $0.003/分钟，朗读约 $0.015/分钟。MOCK_AI=true 时返回固定内容。
VOICE_STT_MODEL=gpt-4o-mini-transcribe
VOICE_TTS_MODEL=gpt-4o-mini-tts
# 可选音色：alloy | ash | ballad | coral | echo | sage | shimmer | verse
VOICE_TTS_VOICE=alloy

# docker (safe, default) | subprocess (dev-only, NO isolation; needs the
# language toolchains installed locally: python3/node/go/javac/g++)
SANDBOX_MODE=docker
# Docker mode uses per-language images (ai-coach-sandbox-python, -javascript,
# -go, -java, -cpp). Build them all with: infra/sandbox/build.sh
SANDBOX_TIMEOUT_SECONDS=10

CORS_ORIGINS=http://localhost:3000

# ---- Frontend (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
